# =============================================================================
# Ativa Dash — variáveis na RAIZ do repositório (mesmo padrão do Ativafix/Primecamp)
# Copie para .env na raiz:  copy .env.example .env   (Windows)  |  cp .env.example .env
# Não commite o .env (já está no .gitignore).
# =============================================================================

NODE_ENV=development
PORT=3000

# --- Opção B (estilo Ativafix): variáveis separadas — a API monta DATABASE_URL sozinha ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ativa_dash
DB_USER=ativadash
DB_PASSWORD=ativadash_local_dev
# DB_SSL=true
# DB_SCHEMA=public

# --- Opção A: URL completa (se preencher, ignora montagem a partir de DB_* acima) ---
# DATABASE_URL="postgresql://ativadash:ativadash_local_dev@localhost:5432/ativa_dash?schema=public"

JWT_SECRET=change-me-jwt-secret-local
JWT_REFRESH_SECRET=change-me-refresh-secret-local
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

PLATFORM_ADMIN_EMAILS=

# Google / Meta (opcional em dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
META_APP_ID=
META_APP_SECRET=

# --- SMTP (recuperação de senha / e-mails transacionais) ---
# Hostinger: 465 (SSL, SMTP_SECURE=true) ou 587 (STARTTLS, SMTP_SECURE=false).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@ativadash.com
SMTP_PASS=
SMTP_FROM_NAME=Ativa DASH
SMTP_FROM_EMAIL=contato@ativadash.com
# Tempo (minutos) de validade do link de redefinição (padrão 60).
# PASSWORD_RESET_TTL_MIN=60
