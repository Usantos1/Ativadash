# Base URL da API (sem /api no final — o app acrescenta /api).
#
# Recomendado se NÃO há Postgres no PC (tudo consulta/altera pela API na nuvem):
#   copie .env.local.example → .env.local com VITE_API_URL=https://api.ativadash.com
#   veja docs/DEV-APENAS-API.md — na VPS, FRONTEND_URL deve incluir http://127.0.0.1:5173 e localhost:5173
#
# Vazio em dev: proxy /api → backend local (porta 3000 ou ATIVADASH_API_PORT).
# VITE_API_URL=

# Agência filial: menu + rotas como operação completa (ADS, Projetos, Lançamentos, Equipe). Default: omitido = enxuto.
# VITE_AGENCY_BRANCH_EXPANDED_OPS=1
