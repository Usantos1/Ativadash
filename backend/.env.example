# Copie para backend/.env OU use um único .env na RAIZ do repositório (recomendado, igual Ativafix).
# Sobrescritas locais (gitignore): backend/.env.local — veja .env.local.example (Postgres "postgres" no Windows).
# Ordem: raiz/.env → backend/.env → raiz/.env.local → backend/.env.local (último ganha).

NODE_ENV=development
PORT=3000

# ---------------------------------------------------------------------------
# Opção estilo Ativafix (raiz ou aqui): DB_* — a API monta DATABASE_URL automaticamente
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ativa_dash
# DB_USER=ativadash
# DB_PASSWORD=ativadash_local_dev
# DB_SSL=false
# DB_SCHEMA=public

# ---------------------------------------------------------------------------
# PostgreSQL — formato Prisma (use esta linha OU DB_* acima, não precisa dos dois):
# postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
#
# Padrão documentado no repositório (dev local / Docker Compose na raiz):
#   Usuário:     ativadash
#   Senha:       ativadash_local_dev   (troque se quiser; mantenha a URL alinhada)
#   Banco:       ativa_dash
#   Porta:       5432
#   Host:        localhost
#
# Exemplo exato (aspas recomendadas no Windows):
DATABASE_URL="postgresql://ativadash:ativadash_local_dev@localhost:5432/ativa_dash?schema=public"
#
# Para logar localmente com a MESMA conta/senha da produção: aponte esta URL para o
# PostgreSQL oficial (via túnel SSH ou rede restrita). NUNCA commite essa URL.
# Guia: docs/DEV-BANCO-OFICIAL.md
#
# Senha com caracteres especiais: codifique na URL (@ → %40, # → %23, etc.)
# ---------------------------------------------------------------------------

JWT_SECRET=change-me-jwt-secret-local
JWT_REFRESH_SECRET=change-me-refresh-secret-local
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Uma ou várias origens (vírgula). CORS aceita todas; a primeira é usada em redirects OAuth.
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# Express atrás de proxy (Nginx, etc.). Local direto: pode omitir (default true).
# TRUST_PROXY=false

# Opcional: e-mails (vírgula) com acesso a /api/platform/*
PLATFORM_ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Health (após subir a API)
#   GET http://localhost:3000/api/health      → processo OK
#   GET http://localhost:3000/api/health/db   → PostgreSQL acessível via Prisma
# ---------------------------------------------------------------------------

# Google Ads / Meta (opcional em dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
META_APP_ID=
META_APP_SECRET=
