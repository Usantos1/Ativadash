generator client {
  provider = "prisma-client-js"
}

// Local: Postgres + DATABASE_URL no backend/.env — ver docs/LOCAL-SETUP.md
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Estado operacional do workspace na visão da matriz (revenda / multiempresa)
enum WorkspaceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

/// Tipo de organização filha no ecossistema da matriz (painel /revenda)
enum ResellerOrgKind {
  AGENCY
  CLIENT
}

/// Fonte primária do tipo de tenant (novos fluxos). `resellerOrgKind` é legado.
enum OrganizationKind {
  MATRIX
  DIRECT
  CLIENT_WORKSPACE
}

/// Conta ou ativo externo sujeito a AssetAccessGrant
enum GrantAssetType {
  META_AD_ACCOUNT
  META_BUSINESS
  GOOGLE_ADS_CUSTOMER
  GOOGLE_MCC
  WEBHOOK_ENDPOINT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  /// Primeiro nome explícito (opcional). Se vazio, o app usa a primeira palavra de `name`.
  firstName String?
  /// Suspensão administrativa (matriz / plataforma): bloqueia login
  suspendedAt DateTime?
  /// Após reset de senha pelo admin: exige troca no próximo login
  mustChangePassword Boolean @default(false)
  /// Último login bem-sucedido (atualizado no auth)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  memberships Membership[]
  refreshTokens RefreshToken[]
  invitationsSent Invitation[] @relation("InvitationInvitedBy")
  matrixWorkspaceGrants MatrixWorkspaceGrant[] @relation("MatrixWorkspaceGrantUser")
  assetAccessGrants     AssetAccessGrant[]     @relation("AssetAccessGrantUser")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  /// Tipo de tenant (matriz, empresa direta ou workspace de cliente). Fonte primária.
  organizationKind OrganizationKind @default(DIRECT)
  /// Agência/revenda: empresas filhas (cada uma com dados isolados)
  parentOrganizationId String?
  parentOrganization     Organization?  @relation("OrgHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  childOrganizations     Organization[] @relation("OrgHierarchy")
  /// Se true (padrão), limites de plano seguem o plano da organização mãe
  inheritPlanFromParent Boolean @default(true)
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id])
  /// Governança na central de revenda (matriz): pausar / arquivar sem apagar histórico
  workspaceStatus WorkspaceStatus @default(ACTIVE)
  /// Observação interna visível na gestão de workspaces (matriz)
  workspaceNote   String?         @db.Text
  /// Filho: agência revenda vs empresa final. Matriz: null.
  resellerOrgKind ResellerOrgKind?
  /// Na raiz (sem pai): habilita revenda de planos, painel matriz e criação de filhos na hierarquia.
  resellerPartner Boolean @default(false)
  /// Razão social (opcional)
  legalName String?
  /// CNPJ — armazenado somente com dígitos
  taxId String?
  /// E-mail de contato / administrador principal da empresa cliente
  contactEmail String?
  /// WhatsApp — preferencialmente só dígitos (ex.: 5511999999999)
  phoneWhatsapp String?
  addressLine1    String?
  addressNumber   String?
  addressDistrict String?
  addressCity     String?
  addressState    String?
  /// CEP — somente dígitos
  addressPostalCode String?
  /// Sobrescreve flags do plano (merge parcial sobre Plan.features JSON)
  featureOverrides Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  subscription      Subscription?
  limitsOverride    SubscriptionLimitsOverride?

  memberships   Membership[]
  clients       ClientAccount[]
  projects      Project[]
  integrations       Integration[]
  dashboards         Dashboard[]
  goals              Goal[]
  marketingSettings  MarketingSettings?
  invitations   Invitation[]
  metricsSnapshots MetricsSnapshot[]
  webhookEndpoints WebhookEndpoint[]
  webhookEvents    WebhookEvent[]
  alertRules       AlertRule[]

  matrixGrantsAsMatrix   MatrixWorkspaceGrant[] @relation("MatrixWorkspaceGrantMatrix")
  matrixGrantsAsWorkspace MatrixWorkspaceGrant[] @relation("MatrixWorkspaceGrantWorkspace")
  assetAccessGrants      AssetAccessGrant[]
  googleAdsCustomerAssignments GoogleAdsCustomerAssignment[]
  metaAdsAssignments         MetaAdsAssignment[]

  @@index([parentOrganizationId])
  @@index([organizationKind])
}

/// Usuário da matriz com acesso a um workspace filho (escopo agency_ops ou refinamento de owner/admin).
model MatrixWorkspaceGrant {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation("MatrixWorkspaceGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  matrixOrganizationId    String
  matrixOrganization      Organization @relation("MatrixWorkspaceGrantMatrix", fields: [matrixOrganizationId], references: [id], onDelete: Cascade)
  workspaceOrganizationId String
  workspaceOrganization   Organization @relation("MatrixWorkspaceGrantWorkspace", fields: [workspaceOrganizationId], references: [id], onDelete: Cascade)
  /// Canais permitidos (strings estáveis: META, GOOGLE, …). Vazio + política em código.
  allowedChannels         String[] @default([])
  createdByUserId         String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([userId, workspaceOrganizationId])
  @@index([matrixOrganizationId])
  @@index([workspaceOrganizationId])
}

/// Restrição fina por conta de anúncio (ou outro ativo) dentro do workspace.
model AssetAccessGrant {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation("AssetAccessGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assetType      GrantAssetType
  externalId     String
  label          String?
  createdByUserId String?
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId, assetType, externalId])
  @@index([organizationId, assetType])
}

/// Auditoria genérica (plataforma, matriz, workspace).
model AuditLog {
  id             String   @id @default(cuid())
  actorUserId    String
  organizationId String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

/// Trilha de auditoria do painel master de revenda (escopo matriz)
model ResellerAuditLog {
  id          String   @id @default(cuid())
  matrixOrgId String
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([matrixOrgId, createdAt])
  @@index([matrixOrgId, action, createdAt])
}

/// Convite por e-mail para novo membro da organização
model Invitation {
  id             String   @id @default(cuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String   @default("member")
  token          String   @unique
  invitedByUserId String
  invitedBy      User     @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([email])
}

/// Cache opcional de métricas (sincronização / worker)
model MetricsSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source         String
  rangeKey       String
  payload        String   @db.Text
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([organizationId, source, rangeKey])
  @@index([organizationId])
}

/// Objetivo principal de leitura do workspace (dashboard, funil, KPIs, insights)
enum BusinessGoalMode {
  LEADS
  SALES
  HYBRID
}

/// Metas e alertas de performance de marketing por organização
model MarketingSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Prioridade de métricas no painel (padrão HYBRID = comportamento legado)
  businessGoalMode BusinessGoalMode @default(HYBRID)
  /// Rótulo da conversão principal em contas de lead (ex.: Oportunidade, Agendamento)
  primaryConversionLabel String? @db.VarChar(120)
  /// Em modo LEADS, exibir blocos de receita/compras com destaque (senão ficam secundários na UI)
  showRevenueBlocksInLeadMode Boolean @default(false)

  /// CPA alvo (BRL) — alerta quando o CPA real ultrapassar
  targetCpaBrl   Decimal? @db.Decimal(14, 2)
  /// CPA máximo tolerável (BRL) — alerta crítico
  maxCpaBrl      Decimal? @db.Decimal(14, 2)
  /// ROAS mínimo desejado (ex.: 3 = R$ 3 de receita por R$ 1 investido)
  targetRoas     Decimal? @db.Decimal(10, 4)

  /// Mínimo de resultados (conv. Google + leads + vendas Meta) para avaliar CPA
  minResultsForCpa     Int      @default(5)
  /// Gasto mínimo no período (BRL) para disparar alertas de CPA/ROAS
  minSpendForAlertsBrl Decimal? @db.Decimal(14, 2)

  alertsEnabled        Boolean @default(true)
  alertCpaAboveMax     Boolean @default(true)
  alertCpaAboveTarget  Boolean @default(true)
  alertRoasBelowTarget Boolean @default(true)

  /// Token da API Ativa CRM (Conexões → WhatsApp). Não retornar em APIs públicas.
  ativaCrmApiToken          String?   @db.Text
  /// WhatsApp para alertas (apenas dígitos; ex.: 5511999999999)
  ativaCrmNotifyPhone       String?
  /// Enviar alertas críticos/aviso por WhatsApp via Ativa CRM
  ativaCrmAlertsEnabled     Boolean   @default(false)
  /// Evita spam: último envio de alerta por WhatsApp
  lastAtivaCrmAlertSentAt   DateTime?
  /// Último envio bem-sucedido do fluxo "Testar" (integração)
  lastAtivaCrmTestSentAt    DateTime?

  /// Overrides por canal: { "meta": { "targetCpaBrl": ... }, "google": { ... } }
  goalsByChannel Json?
  /// Preferências de automação por canal (UI + futura execução)
  automationsByChannel Json?
  /// Quais eventos disparam WhatsApp por canal
  whatsappAlertsByChannel Json?
  /// Intervalo mínimo entre alertas parecidos (minutos), opcional
  whatsappAlertCooldownMinutes Int?
  /// Último envio WhatsApp por código de alerta (dedupe): { "CUSTOM_RULE:xxx": "ISO-8601", ... }
  whatsappLastOutboundByCode Json?
  /// Modelos por código ou "default": { "default": "*{title}*...", "CUSTOM_RULE": "..." }
  whatsappMessageTemplates Json?
  /// Resumo diário (horário UTC, números): { enabled, hourUtc, minuteUtc?, extraPhones? }
  whatsappDigestSchedule Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Regras de alerta customizadas (Fase 6 — avaliação pode integrar ao motor de insights depois)
model AlertRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// meta | google | all (null = todas as contas)
  appliesToChannel String? @db.VarChar(16)

  name      String @db.VarChar(120)
  /// cpa | roas | spend | ctr (valores atuais do período / agregados)
  metric    String @db.VarChar(32)
  /// gt | gte | lt | lte
  operator  String @db.VarChar(8)
  threshold Decimal @db.Decimal(14, 4)
  /// warning | critical
  severity  String @db.VarChar(16)
  active    Boolean @default(true)

  /// Silêncio por hora (0–23, UTC servidor). Ambos null = sem janela de mute.
  muteStartHour Int?
  muteEndHour   Int?

  /// Incluir esta regra em envios automáticos por WhatsApp (quando disparada)
  notifyWhatsapp Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  occurrences AlertOccurrence[]

  @@index([organizationId])
}

/// Disparos registrados de regras customizadas (dedupe na gravação)
model AlertOccurrence {
  id             String    @id @default(cuid())
  organizationId String
  alertRuleId    String
  alertRule      AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)

  severity    String  @db.VarChar(16)
  title       String  @db.VarChar(200)
  message     String  @db.Text
  metricValue Decimal @db.Decimal(14, 4)

  createdAt DateTime @default(now())
  /// Usuário marcou como visto / resolvido na central de metas
  acknowledgedAt DateTime?

  @@index([organizationId, createdAt])
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  /// Nota interna (admin); não exibir como marketing no app
  descriptionInternal String? @db.Text
  active      Boolean  @default(true)
  /// standard | enterprise | trial | internal | custom
  planType    String   @default("standard")
  /// Flags de recurso (marketing, alertas, webhooks, etc.)
  features    Json     @default("{}")
  maxIntegrations Int   @default(5)
  maxDashboards   Int   @default(10)
  /// Usuarios com login (membership direta nesta org). null = ilimitado
  maxUsers       Int?
  /// Contas comerciais (ClientAccount) por organizacao. null = ilimitado
  maxClientAccounts Int?
  /// Empresas filhas (revenda / multi-empresa). null = ilimitado; 0 = nao pode criar filhas
  maxChildOrganizations Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations Organization[]
  subscriptions Subscription[]
}

/// Assinatura operacional: vínculo org ↔ plano faturado / contratado
model Subscription {
  id               String   @id @default(cuid())
  organizationId   String   @unique
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  /// monthly | quarterly | annual | trial | custom
  billingMode      String   @default("custom")
  /// active | trialing | past_due | canceled
  status           String   @default("active")
  startedAt        DateTime @default(now())
  renewsAt         DateTime?
  endedAt          DateTime?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Limites efetivos customizados por tenant (sobrepõe limites do plano quando preenchido)
model SubscriptionLimitsOverride {
  id                    String   @id @default(cuid())
  organizationId      String   @unique
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  maxUsers              Int?
  maxClientAccounts     Int?
  maxIntegrations       Int?
  maxDashboards         Int?
  maxChildOrganizations Int?
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String   @default("member")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model ClientAccount {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  projects Project[]
  integrations Integration[]
  googleAdsCustomerAssignments GoogleAdsCustomerAssignment[]
  metaAdsAssignments         MetaAdsAssignment[]

  @@index([organizationId])
}

model Project {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  clientAccountId String?
  clientAccount   ClientAccount? @relation(fields: [clientAccountId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  launches Launch[]

  @@index([organizationId])
}

model Launch {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime?
  endDate   DateTime?
  /// Checklist JSON (fases de lançamento) — opcional
  checklistJson String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([projectId])
}

model Integration {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Cliente comercial (menu Clientes) — agrupamento operacional
  clientAccountId String?
  clientAccount   ClientAccount? @relation(fields: [clientAccountId], references: [id], onDelete: SetNull)
  platform       String
  slug           String
  status         String   @default("pending")
  config         String? // JSON string (SQLite-compatible)
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  /// Chave composta usada pelo Prisma em `upsert` / `where: { organizationId_slug: { ... } }`.
  /// No PostgreSQL: índice único `Integration_organizationId_slug_key` (migration `20260320170000_add_integration_organization_slug_unique`).
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, slug])
  @@index([clientAccountId])

  googleAdsAccessibleCustomers GoogleAdsAccessibleCustomer[]
  googleAdsCustomerAssignments GoogleAdsCustomerAssignment[]
  metaAdsAssignments         MetaAdsAssignment[]
}

/// Vínculo explícito: cliente comercial → conta de anúncios Meta (BM + act id numérico).
model MetaAdsAssignment {
  id              String   @id @default(cuid())
  integrationId   String
  integration     Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientAccountId String
  clientAccount   ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  /// Facebook Business ID (ou "__personal__" quando só há /me/adaccounts)
  businessId      String
  /// ID numérico da conta, sem prefixo act_
  adAccountId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([integrationId, clientAccountId])
  @@index([organizationId])
}

/// Contas Google Ads devolvidas por ListAccessibleCustomers + metadados (por integração OAuth).
model GoogleAdsAccessibleCustomer {
  id                String   @id @default(cuid())
  integrationId     String
  integration       Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  customerId        String
  descriptiveName   String?
  currencyCode      String?
  isManager         Boolean  @default(false)
  /// Conta MCC usada como login-customer-id para consultar este customer (filho).
  managerCustomerId String?
  status            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([integrationId, customerId])
  @@index([integrationId])
}

/// Vínculo explícito: cliente comercial → customer Google Ads (sob uma integração OAuth).
model GoogleAdsCustomerAssignment {
  id               String   @id @default(cuid())
  integrationId    String
  integration      Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientAccountId  String
  clientAccount    ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  googleCustomerId String
  loginCustomerId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([integrationId, clientAccountId])
  @@index([organizationId])
}

model Dashboard {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  config         String? // JSON string (SQLite-compatible)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  widgets DashboardWidget[]

  @@index([organizationId])
}

model DashboardWidget {
  id          String   @id @default(cuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  type        String
  config      String? // JSON string (SQLite-compatible)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dashboardId])
}

model Goal {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  type           String
  targetValue    Float
  period         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

/// Fila de ingestão de webhooks HTTP (dedupe por organizationId + eventKey)
enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

/// Endpoint público (URL + segredo HMAC) por workspace
model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /// Slug único global na URL POST /api/hooks/w/{publicSlug}
  publicSlug     String   @unique
  /// Segredo HMAC do corpo bruto. Exibido só na criação; proteja o banco em produção.
  signingSecret  String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events WebhookEvent[]

  @@index([organizationId])
}

model WebhookEvent {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  webhookEndpointId String?
  webhookEndpoint   WebhookEndpoint?   @relation(fields: [webhookEndpointId], references: [id], onDelete: SetNull)
  eventKey          String
  sourceType        String             @default("custom")
  status            WebhookEventStatus @default(RECEIVED)
  rawPayload        Json
  normalizedPayload Json?
  errorMessage      String?            @db.Text
  processedAt       DateTime?
  retryCount        Int                @default(0)
  createdAt         DateTime           @default(now())

  @@unique([organizationId, eventKey])
  @@index([organizationId, createdAt])
  @@index([status, createdAt])
}
