# =============================================================================
# OBRIGATÓRIO após copiar: edite a DATABASE_URL.
# Se o banco está SÓ na VPS: localhost no PC NÃO é esse banco — use túnel SSH + 127.0.0.1:5433
# (veja docs/BANCO-SO-NA-VPS.md e docs/DEV-BANCO-OFICIAL.md).
# Postgres no próprio PC: troque COLOQUE_SUA_SENHA_AQUI pela senha real do usuário postgres.
# =============================================================================

# Senha com caracteres especiais na URL:
#   @ → %40     # → %23     : → %3A     / → %2F     espaço → %20
# Ex.: senha Minha@Senha#1 → Minha%40Senha%231

DATABASE_URL="postgresql://postgres:COLOQUE_SUA_SENHA_AQUI@127.0.0.1:5432/ativa_dash?schema=public"

# Se o banco ativa_dash ainda não existir, crie no pgAdmin ou:
#   psql -U postgres -h 127.0.0.1 -c "CREATE DATABASE ativa_dash OWNER postgres;"
